{
  "theme": "auto",
  "permissions": {
    "allow": [
      "mcp__hub__hub_reply",
      "mcp__hub__hub_send_file",
      "mcp__hub__hub_replay_history",
      "Read(~/.claude/skills/**)",
      "Read(~/Workspace/**)",
      "Read(~/.forge-hub/**)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(which*)",
      "Bash(echo*)",
      "Bash(cat*)"
    ]
  },
  "plansDirectory": "claude-plans",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bash ~/.claude/hooks/pretooluse-guard.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/Ruby/scripts/token_tracker.py",
            "async": true
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/Ruby/scripts/reflection.py",
            "async": true
          }
        ]
      }
    ]
  }
}